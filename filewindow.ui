  <property name="styleSheet">
   <string notr="true">QWidget {
    background-color: #2b2b2b;
    color: #ffffff;
    font-family: &quot;Consolas&quot;;
}

QListWidget {
    background-color: #000000;
    border: 1px solid #555555;
    color: #00ff00;
    font-size: 12pt;
}

QPushButton {
    background-color: #808080;
    color: white;
    border-radius: 4px;
    padding: 8px;
    font-weight: bold;
}
QPushButton:hover { background-color: #808080; }
QPushButton:pressed { background-color: #1a1a1a; }

QPushButton#button_logout {
    background-color: #d9534f;
    color: white;
}
QPushButton#button_logout:hover { background-color: #c9302c; }

QPushButton#button_back, QPushButton#button_next {
    background-color: transparent;
    border: 2px solid #555555;
    border-radius: 15px;
    min-width: 30px;
    min-height: 30px;
}

QTabWidget::pane {
    border: 1px solid #444444;
    background-color: #1e1e1e;
    border-radius: 4px;
}

QTabBar::tab {
    background-color: #2b2b2b;
    color: #aaaaaa;
    padding: 8px 20px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background-color: #1e1e1e;
    color: #00ff00;
    border-bottom: 2px solid #00ff00;
    font-weight: bold;
}

QTabBar::tab:hover {
    background-color: #333333;
    color: white;
}</string>
