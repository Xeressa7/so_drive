  <property name="styleSheet">
   <string notr="true">QWidget {
    background-color: #2b2b2b;
    color: #ffffff;
    font-family: &quot;Consolas&quot;;
}

/* Dosya Listesi Kutusu */
QListWidget {
    background-color: #000000;
    border: 1px solid #555555;
    color: #00ff00; /* Dosyalar yeşil görünsün */
    font-size: 12pt;
}

/* Butonlar */
QPushButton {
    background-color: #808080;
    color: white;
    border-radius: 4px;
    padding: 8px;
    font-weight: bold;
}
QPushButton:hover { background-color: #808080; }
QPushButton:pressed { background-color: #1a1a1a; }

/* Çıkış Butonu Özel Renk (İsteğe bağlı) */
QPushButton#button_logout {
    background-color: #d9534f; /* Kırmızımsı */
    color: white;
}
QPushButton#button_logout:hover { background-color: #c9302c; }
/* --- SADECE NAVİGASYON BUTONLARI (Şeffaf Olsun) --- */

QPushButton#button_back, QPushButton#button_next {
    background-color: transparent;   /* Arka plan şeffaf (İkon ön planda) */
    border: 2px solid #555555;       /* GRİ ÇERÇEVE (İstediğin özellik bu) */
    border-radius: 15px;             /* Köşeler yuvarlak */
    min-width: 30px;                 /* Buton çok daralmasın */
    min-height: 30px;
}
/* Genel Tab Çerçevesi */
QTabWidget::pane {
    border: 1px solid #444444;
    background-color: #1e1e1e; /* İçerik alanı rengi */
    border-radius: 4px;
}

/* Sekme Başlıklarının Olduğu Şerit */
QTabBar::tab {
    background-color: #2b2b2b; /* Pasif sekme rengi */
    color: #aaaaaa;            /* Pasif yazı rengi */
    padding: 8px 20px;         /* Genişlik ve yükseklik */
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    margin-right: 2px;         /* Sekmeler birbirine yapışmasın */
}

/* Seçili Olan (Aktif) Sekme */
QTabBar::tab:selected {
    background-color: #1e1e1e; /* İçerikle aynı renk olsun ki bütünleşsin */
    color: #00ff00;            /* Aktif dosya ismi YEŞİL yansın */
    border-bottom: 2px solid #00ff00; /* Altına yeşil çizgi çekelim */
    font-weight: bold;
}

/* Üzerine Gelince */
QTabBar::tab:hover {
    background-color: #333333;
    color: white;
}</string>
